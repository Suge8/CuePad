{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CuePad",
  "version": "0.1.0",
  "identifier": "com.sugeh.cuepad",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "bun run build"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:cuepad.db"]
    }
  },
  "app": {
    "windows": [
      {
        "title": "CuePad",
        "width": 1200,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
